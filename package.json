{
  "name": "lawlink-next",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.9.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"pnpm --filter @lawlink/api dev\" \"pnpm --filter @lawlink/web dev\"",
    "build": "pnpm -r run build",
    "start": "pnpm --filter @lawlink/api start",
    "preview": "pnpm build && pnpm start",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  }
}
