# lawlink-next API — copy to .env for local dev (.env is gitignored).
# server.ts loads this automatically (Node native process.loadEnvFile).

# REQUIRED. Strong random secret for signing/verifying login JWTs. There is no
# fallback — the API refuses to start without it. Generate one with:
#   openssl rand -hex 32
# The literal "dev-secret-change-me" is rejected as a placeholder.
LAWLINK_JWT_SECRET=replace-with-openssl-rand-hex-32

# libSQL/SQLite connection. Local file for self-host; a Turso/libSQL URL works too.
LAWLINK_DB_URL=file:./lawlink.db

# Port for the single-origin server (serves SPA + /api).
PORT=8787

# Optional: override where the built SPA lives (defaults to ../web/dist).
# LAWLINK_WEB_DIST=../web/dist
