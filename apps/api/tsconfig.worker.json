{
  "extends": "../../tsconfig.base.json",
  // Cloudflare Worker + Durable Object entry. Uses Workers ambient globals
  // (Request/Response/DurableObject/crypto) instead of Node's, so it is a
  // SEPARATE program from the Node tsconfig (their `File`/`Blob` globals differ).
  "compilerOptions": {
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/worker.ts", "src/do.ts"]
}
